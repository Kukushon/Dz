# Существует платный калькулятор, который берет плату за каждую арифметическую операцию.
# Стоимость каждой операции равна 5% от числа, которое является результатом операции.
# Найти оптимальный порядок сложения N натуральных чисел, чтобы минимизировать затраты
# на вычисление их суммы.
# Ввод: число N, в следующих строках N натуральных чисел.
# Вывод: минимальная сумма, необходимая для нахождения суммы этих чисел, с точностью до
# двух десятичных знаков.
# Пример: Необходимо сложить числа 10, 11, 12 и 13. Если сначала сложить 10 и 11(1, 05),
# потом результат - с 12(1, 65), и затем - с 13(2, 3), то всего необходимо заплатить - 5.
# Если же сначала отдельно сложить 10 и 11(1, 05), потом - 12 и 13(1, 25), а затем сложить
# между собой два полученных числа(2, 3), то в итоге получить - 4, 6.

with open("input.txt", "r") as f:
    n = int(f.readline())
    nums = [int(f.readline()) for i in range(n)]
cost = 0
while len(nums) > 1:
    min1 = min(nums)
    nums.remove(min1)
    min2 = min(nums)
    nums.remove(min2)
    s = min1 + min2
    cost += 0.05 * s
    nums.append(s)
with open("output.txt", "w") as f:
    f.write("%.2f"%cost)

