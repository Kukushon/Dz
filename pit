# Дана последовательность символов с цифрами, заканчивающаяся точкой. 
# Найти минимальное число из цифр 1 - 9, которые не встречаются в последовательности.
# Если все цифры от 1 до 9 встречаются - вывести 0.
# Вход: "1A734B39."
# Выход: 2568

s = input("Введите символы: ")
numbers = "123456789"
for i in s:
    if i in numbers:
        numbers = numbers.replace(i, "")
if numbers == "":
    print(0)
else:
    print(numbers)

