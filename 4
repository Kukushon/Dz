#include <iostream>
#include <fstream>
#include <vector>
#include <cmath>

using namespace std;

const double EPS = 1e-6;
const int MAX_ITER = 100;

vector<double> gauss(vector<vector<double>> A, vector<double> b) {
    int n = A.size();

    for (int i = 0; i < n; i++) {
        double div = A[i][i];
        for (int j = i; j < n; j++) A[i][j] /= div;
        b[i] /= div;

        for (int k = i + 1; k < n; k++) {
            double factor = A[k][i];
            for (int j = i; j < n; j++) A[k][j] -= factor * A[i][j];
            b[k] -= factor * b[i];
        }
    }

    vector<double> x(n, 0);
    for (int i = n - 1; i >= 0; i--) {
        x[i] = b[i];
        for (int j = i + 1; j < n; j++) {
            x[i] -= A[i][j] * x[j];
        }
    }
    return x;
}

vector<double> G1(const vector<double>& x) {
    vector<double> result(2);
    result[0] = sin(x[1]) - 0.5;
    result[1] = cos(x[0]) - 0.5;
    return result;
}

vector<double> G2(const vector<double>& x) {
    vector<double> result(2);
    result[0] = x[1] * x[1] - 0.4;
    result[1] = sin(x[0]) - 0.2;
    return result;
}

vector<double> picard(vector<vector<double>> A, vector<double> x0, int func_num) {
    int n = A.size();
    vector<double> x = x0;

    for (int k = 0; k < MAX_ITER; k++) {
        vector<double> x_old = x;

        vector<double> Gx;
        if (func_num == 1) Gx = G1(x_old);
        else Gx = G2(x_old);

        vector<double> b(2);
        b[0] = -Gx[0];
        b[1] = -Gx[1];

        x = gauss(A, b);

        double diff = max(fabs(x[0] - x_old[0]), fabs(x[1] - x_old[1]));
        if (diff < EPS) {
            break;
        }
    }

    return x;
}

