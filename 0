#include <iostream>
#include <vector>
#include <iomanip>
#include <cmath>
using namespace std;

int main() {
    setlocale(LC_ALL, "ru");
    int n;
    cout << "Введите размер системы: ";
    cin >> n;

    vector<vector<double>> mat(n, vector<double>(n + 1));
    vector<vector<double>> original(n, vector<double>(n + 1));

    cout << "Введите A|b:" << endl;
    for (int i = 0; i < n; i++) {
        for (int j = 0; j <= n; j++) {
            cin >> mat[i][j];
            original[i][j] = mat[i][j];
        }
    }

    for (int i = 0; i < n; i++) {
        int maxRow = i;
        for (int k = i + 1; k < n; k++)
            if (abs(mat[k][i]) > abs(mat[maxRow][i]))
                maxRow = k;
        swap(mat[i], mat[maxRow]);
        for (int k = i + 1; k < n; k++) {
            double factor = mat[k][i] / mat[i][i];
            for (int j = i; j <= n; j++)
                mat[k][j] -= factor * mat[i][j];
        }
    }

    for (int i = 0; i < n; i++) {
        if (abs(mat[i][i]) < 1e-10) {
            cout << "Ошибка: Система не имеет единственного решения!" << endl;
            return 1;
        }
    }
    vector<double> x(n);
    for (int i = n - 1; i >= 0; i--) {
        x[i] = mat[i][n];
        for (int j = i + 1; j < n; j++)
            x[i] -= mat[i][j] * x[j];
        x[i] /= mat[i][i];
    }

    cout << "\nРешение системы:" << endl;
    for (int i = 0; i < n; i++) {
        cout << "x[" << i << "] = " << fixed << setprecision(6) << x[i] << endl;
    }

    cout << "\nПроверка:" << endl;
    for (int i = 0; i < n; i++) {
        double calculated_b = 0.0;
        for (int j = 0; j < n; j++) {
            calculated_b += original[i][j] * x[j];
        }
        cout << "b[" << i << "] = " << calculated_b << endl;
    }

    return 0;
}
