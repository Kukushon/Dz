#include <fstream>
#include <vector>
#include <cmath>
#include <iomanip>

using namespace std;

typedef vector<double> vec;
typedef vector<vec> mat;

mat multiply(const mat& A, const mat& B) {
    int n = A.size();
    mat C(n, vec(n, 0));
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            for (int k = 0; k < n; k++) {
                C[i][j] += A[i][k] * B[k][j];
            }
        }
    }
    return C;
}

double trace(const mat& A) {
    double sum = 0;
    for (int i = 0; i < A.size(); i++) {
        sum += A[i][i];
    }
    return sum;
}

vec getEigenvector(const mat& A, double lambda) {
    int n = A.size();
    vec v(n, 1.0);

    for (int iter = 0; iter < 1000; iter++) {
        vec Av(n, 0);
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {
                Av[i] += A[i][j] * v[j];
            }
        }

        double norm = 0;
        for (double x : Av) norm += x * x;
        norm = sqrt(norm);

        for (int i = 0; i < n; i++) {
            v[i] = Av[i] / norm;
        }
    }
    return v;
}

int main() {
    ifstream in("input.txt");
    int n;
    in >> n;

    mat A(n, vec(n));
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            in >> A[i][j];
        }
    }
    in.close();

    mat Ak = A;
    mat Akp1 = multiply(A, A);

    for (int k = 1; k < 50; k++) {
        double Sp_Ak = trace(Ak);
        double Sp_Akp1 = trace(Akp1);

        double lambda = Sp_Akp1 / Sp_Ak;

        Ak = Akp1;
        Akp1 = multiply(Akp1, A);
    }

    double Sp_Ak = trace(Ak);
    double Sp_Akp1 = trace(Akp1);
    double lambda = Sp_Akp1 / Sp_Ak;

    vec eigenvector = getEigenvector(A, lambda);

    ofstream out("output.txt");
    out << fixed << setprecision(10);
    out << lambda << "\n";
    for (int i = 0; i < n; i++) {
        out << eigenvector[i];
        if (i < n - 1) out << " ";
    }
    out.close();

    return 0;
}
