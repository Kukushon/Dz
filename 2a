#include <iostream>
#include <vector>
#include <fstream>
#include <cmath>

using namespace std;

typedef vector<vector<double>> Matrix;
typedef vector<double> Vector;

Vector multiply(const Matrix& A, const Vector& x) {
    int n = A.size();
    Vector result(n, 0.0);

    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            result[i] += A[i][j] * x[j];

    return result;
}

Matrix multiplyMatrix(const Matrix& A, const Matrix& B) {
    int n = A.size();
    Matrix C(n, Vector(n, 0.0));

    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            for (int k = 0; k < n; k++)
                C[i][j] += A[i][k] * B[k][j];

    return C;
}

Matrix pMatrix(Matrix A, int n) {
    Matrix result = A;

    for (int i = 0; i < n; i++) {
        result = multiplyMatrix(result, result);
    }

    return result;
}

void normalize(Vector& x) {
    double norm = 0;
    for (double v : x)
        norm += v * v;

    norm = sqrt(norm);

    for (double& v : x)
        v /= norm;
}

double cLambda(const Matrix& A, const Vector& x) {
    Vector Ax = multiply(A, x);

    double num = 0, den = 0;
    for (int i = 0; i < x.size(); i++) {
        num += Ax[i] * x[i];
        den += x[i] * x[i];
    }

    return num / den;
}

