#include <iostream>
#include <fstream>
#include <vector>
#include <sstream>
#include <cmath>

using namespace std;

vector<vector<double>> mult(const vector<vector<double>>& A, const vector<vector<double>>& B)
{
    int n = A.size();
    vector<vector<double>> C(n, vector<double>(n, 0));
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            for (int k = 0; k < n; k++)
                C[i][j] += A[i][k] * B[k][j];
    return C;
}

vector<double> multVec(const vector<vector<double>>& A, const vector<double>& x)
{
    int n = A.size();
    vector<double> y(n, 0);
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            y[i] += A[i][j] * x[j];
    return y;
}

double sp(const vector<vector<double>>& A)
{
    double s = 0;
    for (int i = 0; i < A.size(); i++)
        s += A[i][i];
    return s;
}

int main()
{
    ifstream fin("vvod.txt");
    ofstream fout("vivod.txt");

    vector<vector<double>> A;
    string line;

    while (getline(fin, line))
    {
        stringstream ss(line);
        vector<double> row;
        double val;

        while (ss >> val)
            row.push_back(val);

        if (!row.empty())
            A.push_back(row);
    }

    int n = A.size();


    int p = 3;
    vector<vector<double>> Ak = A;

    for (int i = 0; i < p; i++)
        Ak = mult(Ak, Ak);
    vector<vector<double>> Ak1 = mult(Ak, A);

    double spk = sp(Ak);
    double spk1 = sp(Ak1);

    double lambda = spk1 / spk;

    fout << "lambda = " << lambda << endl;

    vector<double> x(n, 1);

    for (int iter = 0; iter < 20; iter++)
    {
        vector<double> y = multVec(A, x);

        double norm = fabs(y[0]);
        for (int i = 1; i < n; i++)
            if (fabs(y[i]) > norm)
                norm = fabs(y[i]);

        for (int i = 0; i < n; i++)
            x[i] = y[i] / norm;
    }

    fout << "vector: ";
    for (double v : x)
        fout << v << " ";
    fin.close();
    fout.close();
    cout << "OK";
    return 0;
}
