#include <iostream>
#include <vector>
#include <fstream>
#include <cmath>

using namespace std;

typedef vector<vector<double>> Matrix;
typedef vector<double> Vector;

Vector multiply(const Matrix& A, const Vector& x) {
    int n = A.size();
    Vector result(n, 0.0);

    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            result[i] += A[i][j] * x[j];

    return result;
}

Matrix multiplyMatrix(const Matrix& A, const Matrix& B) {
    int n = A.size();
    Matrix C(n, Vector(n, 0.0));

    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            for (int k = 0; k < n; k++)
                C[i][j] += A[i][k] * B[k][j];

    return C;
}

Matrix pMatrix(Matrix A, int n) {
    Matrix result = A;

    for (int i = 0; i < n; i++) {
        result = multiplyMatrix(result, result);
    }

    return result;
}

void normalize(Vector& x) {
    double norm = 0;
    for (double v : x)
        norm += v * v;

    norm = sqrt(norm);

    for (double& v : x)
        v /= norm;
}

int main() {
    ifstream in("input.txt");
    ofstream out("output.txt");
    
    int n;
    in >> n;

    Matrix A(n, Vector(n));
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            in >> A[i][j];

    Vector y(n, 1.0);


    double lambda_old = 0;
    double lambda_new = 0;
    double eps = 1e-6;

    Matrix B = A;
    int p = 0;

    while (true)
    {
        y = multiply(B, y);
        normalize(y);

        Vector Ay = multiply(A, y);

        lambda_new = 0;
        double denom = 0;

        for (int i = 0; i < y.size(); i++)
        {
            lambda_new += Ay[i] * y[i];
            denom += y[i] * y[i];
        }

        lambda_new /= denom;

        if (fabs(lambda_new - lambda_old) < eps)
            break;

        lambda_old = lambda_new;

        Matrix B_next = multiplyMatrix(B, B);
        B = B_next;
        p++;
    }

    out << "lambda: " << lambda_new << endl;
    out << "vector:" << endl;

    for (double v : y)
        out << v << " ";

    in.close();
    out.close();

    return 0;
}
