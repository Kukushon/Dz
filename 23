#include <iostream>
#include <fstream>
#include <cmath>
#include <string>

using namespace std;

// система
void f(double t, double x, double y,
    double& dx, double& dy) {
    dx = 2 * y - x;
    dy = 4 * y - 3 * x + (exp(3 * t) / (exp(2 * t) + 1));
}

// RK2
void rk2_step(double t, double& x, double& y, double h) {
    double k1x, k1y;
    f(t, x, y, k1x, k1y);

    double xm = x + 0.5 * h * k1x;
    double ym = y + 0.5 * h * k1y;

    double k2x, k2y;
    f(t + 0.5 * h, xm, ym, k2x, k2y);

    x += h * k2x;
    y += h * k2y;
}

// формат
string fmt(double v) {
    string s = to_string(v);
    while (!s.empty() && s.back() == '0') s.pop_back();
    if (!s.empty() && s.back() == '.') s.pop_back();
    for (char& c : s)
        if (c == '.') c = ',';
    return s;
}

// решение
void solve(double h, ofstream& fout) {
    double t = 0.0;
    double x = 3.87765;
    double y = 5.66305;

    int steps = (int)(3.0 / h);

    fout << "h = " << h << "\n";
    fout << "t\t y1\t y2\n";

    for (int i = 0; i <= steps; i++) {
        fout << fmt(t) << "\t"
            << fmt(x) << "\t"
            << fmt(y) << "\n";

        rk2_step(t, x, y, h);
        t += h;
    }

    fout << "\n\n";
}

int main() {
    ofstream fout("output.txt");

    solve(0.1, fout);
    solve(0.2, fout);

    fout.close();
    return 0;
}
