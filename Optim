//Метод золотого сечения
#include <iostream>
#include <cmath>
#include <iomanip>
using namespace std;

// Функция
double f(double x) {
    return x * x - 6 * x + 13;
}

int main() {
    setlocale(LC_ALL, "ru");
    double a = 0;        // левая граница
    double b = 10;       // правая граница
    double eps = 0.5;    // точность

    const double phi = (1 + sqrt(5)) / 2;
    const double r = 2 - phi; // = 0.382

    int k = 0;

    cout << fixed << setprecision(2);
    cout << "Начальный интервал: [" << a << ", " << b << "]\n";

    while ((b - a) > eps) {
        // вычисляем точки
        double y = a + r * (b - a);
        double z = a + b - y;

        cout << "\nШаг " << k << ":\n";
        cout << "y = " << y << "\tz = " << z << endl;
        cout << "f(y) = " << f(y) << "\tf(z) = " << f(z) << endl;


        // сравнение
        if (f(y) <= f(z)) {
            cout << "f(y) <= f(z) \tb = z\n";
            b = z;
        }
        else {
            cout << "f(y) > f(z) \ta = y\n";
            a = y;
        }
        cout << "L = [" << a << " " << b << "]" << endl;
        k++;
    }

    // итог
    double x_min = (a + b) / 2;
    double pogr = (b - a) / 2;

    cout << "\nФинальный интервал: [" << a << ", " << b << "]\n";
    cout << "Минимум x = " << x_min << " +- " << pogr << endl;
    cout << "f(x) = " << f(x_min) << endl;

    return 0;
}

//Метод дихотомии
#include <iostream>
#include <cmath>
#include <iomanip>
using namespace std;

double f(double x) {
    return x * x - 6 * x + 13;
}

int main() {
    setlocale(LC_ALL, "ru");
    double a = 0.0;
    double b = 10.0;
    double eps = 0.5;
    double L = 1.0;
    int k = 0;

    while ((b - a) > L) {

        double y = (a + b - eps) / 2.0;
        double z = (a + b + eps) / 2.0;

        double fy = f(y);
        double fz = f(z);
        cout << fixed << setprecision(2);
        // Считаем точки
        cout << "Шаг " << k << endl;
        cout << "y = " << y << "\tz = " << z << endl;
        cout << "f(y) = " << fy << "\tf(z) = " << fz << endl;

        // Сужаем интервал
        if (fy < fz) {
            b = z;
            cout << "f(y) < f(z)\tb = z" << endl;
        }
        else {
            a = y;
            cout << "f(y) > f(z)\ta = y" << endl;
        }

        // Выводим полученный отрезок 
        cout << "L = [" << a << "; " << b << "]" << endl;
        cout << "Длина: " << b - a << endl << endl;

        k++;
    }

    // Приближённое решение - середина интервала
    double x_opt = (a + b) / 2.0;
    double pogr = (b - a) / 2.0;
    cout << "Ответ:" << endl;
    cout << "x* = " << x_opt << " +- " << pogr << endl;
    cout << "f(x*) = " << f(x_opt) << endl;

    return 0;
}

//Метод Фиббоначи
#include <iostream>
#include <vector>
#include <cmath>
#include <iomanip>

double f(double x) {
    return x * x - 6 * x + 13;
}

int main() {
    std::setlocale(LC_ALL, "ru");

    double a = 0.0;
    double b = 10.0;
    double L = 1.0;
    std::vector<int> F = { 1, 1 };
    while (F.back() < (b - a) / L) {
        F.push_back(F[F.size() - 1] + F[F.size() - 2]);
    }

    int N = F.size() - 1;

    std::cout << "N = " << N << "\n\n";

    //Начальные точки
    double y = a + (double)F[N - 2] / F[N] * (b - a);
    double z = a + (double)F[N - 1] / F[N] * (b - a);

    double fy = f(y);
    double fz = f(z);

    std::cout << std::fixed << std::setprecision(3);

    //Основной цикл
    for (int k = 1; k <= N - 3; k++) {

        std::cout << "Шаг " << k << "\n";
        std::cout << "a = " << a << "\tb = " << b << "\n";
        std::cout << "y = " << y << "\tz = " << z << "\n";
        std::cout << "f(y) = " << fy << "\tf(z) = " << fz << "\n";

        if (fy < fz) {
            b = z;
            z = y;
            fz = fy;

            y = a + (double)F[N - k - 2] / F[N - k] * (b - a);
            fy = f(y);

            std::cout << "f(y) < f(z)\n";
        }
        else {
            a = y;
            y = z;
            fy = fz;

            z = a + (double)F[N - k - 1] / F[N - k] * (b - a);
            fz = f(z);

            std::cout << "f(y) > f(z)\n";
        }

        std::cout << "Интервал: [" << a << "; " << b << "]\n\n";
    }

    //Финальный шаг
    double eps = 0.5;
    double z_final = y + eps;
    double fy_final = f(y);
    double fz_final = f(z_final);
    std::cout << "f(y) = " << fy_final << "\tf(z) = " << fz_final << "\n";
    if (fy_final < fz_final) {
        b = z_final;
    }
    else {
        a = y;
    }

    // --- Ответ ---
    std::cout << "a = " << a << "\tb = " << b << "\n";
    double x_opt = (a + b) / 2.0;

    std::cout << "Ответ:\n";
    std::cout << "x* = " << x_opt << "\n";
    std::cout << "f(x*) = " << f(x_opt) << "\n";

    return 0;
}
