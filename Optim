#include <iostream>
#include <cmath>
using namespace std;

double f(double x) {
    return x * x - 6 * x + 13;
}

int main() {
    setlocale(LC_ALL, "ru");
    double a = 0.0;
    double b = 10.0;
    double eps = 0.5;
    double L = 1.0;
    int k = 0;

    while ((b - a) > L) {

        double y = (a + b - eps) / 2.0;
        double z = (a + b + eps) / 2.0;

        double fy = f(y);
        double fz = f(z);

        // Считаем точки
        cout << "Итерация " << k << endl;
        cout << "y = " << y << "  z = " << z << endl;
        cout << "f(y) = " << fy << "  f(z) = " << fz << endl;

        // Сужаем интервал
        if (fy < fz) {
            b = z;
            cout << "f(y) < f(z), b = z" << endl;
        }
        else {
            a = y;
            cout << "f(y) > f(z), a = y" << endl;
        }

        // Выводим полученный отрезок 
        cout << "Новый интервал: [" << a << "; " << b << "]" << endl;
        cout << "Длина: " << b - a << endl << endl;

        k++;
    }

    // Приближённое решение - середина интервала
    double x_opt = (a + b) / 2.0;

    cout << "Ответ:" << endl;
    cout << "x* = " << x_opt << " +- 0,5" << endl;
    cout << "f(x*) = " << f(x_opt) << endl;

    return 0;
}
