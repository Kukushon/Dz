#include <iostream>
#include <vector>
#include <cmath>

using namespace std;

int main() {
    int n;
    cout << "Введите размер матрицы n: ";
    cin >> n;

    vector<vector<double>> A(n, vector<double>(n));
    vector<double> y_prev(n), y(n);

    cout << "Введите элементы матрицы A:" << endl;
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            cin >> A[i][j];

    cout << "Введите начальный вектор y0:" << endl;
    for (int i = 0; i < n; i++)
        cin >> y_prev[i];

    double lambda = 0.0, lambda_new = 0.0;
    double eps = 1e-6;
    int maxIter = 1000;

    for (int iter = 0; iter < maxIter; iter++) {

        // y = A * y_prev
        for (int i = 0; i < n; i++) {
            y[i] = 0.0;
            for (int j = 0; j < n; j++) {
                y[i] += A[i][j] * y_prev[j];
            }
        }

        int index = 0;
        for (int i = 0; i < n; i++) {
            if (fabs(y_prev[i]) > 1e-8) {
                index = i;
                break;
            }
        }

        lambda_new = y[index] / y_prev[index];

        if (fabs(lambda_new - lambda) < eps) {
            lambda = lambda_new;
            break;
        }

        lambda = lambda_new;

        double norm = 0.0;
        for (int i = 0; i < n; i++) {
            norm += y[i] * y[i];
        }
        norm = sqrt(norm);

        for (int i = 0; i < n; i++) {
            y_prev[i] = y[i] / norm;
        }
    }

    cout << "\nСтаршее собственное значение: " << lambda << endl;
    cout << "Собственный вектор:" << endl;
    for (int i = 0; i < n; i++) {
        cout << y_prev[i] << " ";
    }
    cout << endl;

    return 0;
}

#include <iostream>
