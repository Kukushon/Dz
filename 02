#include <iostream>
#include <fstream>
#include <vector>
#include <cmath>

using namespace std;

int main() {
    ifstream in("input.txt");
    ofstream out("output.txt");

    int n;
    double eps = 1e-6;
    double delta = 1e-12;
    in >> n;

    vector<vector<double>> A(n, vector<double>(n));
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            in >> A[i][j];

    vector<double> y(n, 1.0);
    vector<double> y_new(n);

    double lambda = 0.0;
    int iter = 0;

    while (iter < 10000) {
        for (int i = 0; i < n; i++) {
            y_new[i] = 0.0;
            for (int j = 0; j < n; j++) {
                y_new[i] += A[i][j] * y[j];
            }
        }
        int idx = -1;
        for (int i = 0; i < n; i++) {
            if (fabs(y[i]) > delta) {
                idx = i;
                break;
            }
        }
        if (idx == -1) {
            return 0;
        }

        double new_lambda = y_new[idx] / y[idx];
        double maxv = 0.0;
        for (int i = 0; i < n; i++)
            if (fabs(y_new[i]) > maxv) maxv = fabs(y_new[i]);
        for (int i = 0; i < n; i++)
            y_new[i] /= maxv;
        if (fabs(new_lambda - lambda) < eps) {
            lambda = new_lambda;
            y = y_new;
            break;
        }

        lambda = new_lambda;
        y = y_new;
        iter++;
    }

    out << "Lambda = " << lambda << endl;
    out << "y:" << endl;
    for (double v : y)
        out << v << endl;

    return 0;
}
