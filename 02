#include <fstream>

using namespace std;

int main() {
    ifstream fin("vvod.txt");
    ofstream fout("vivod.txt");

    int n;
    fin >> n;

    vector<vector<double>> A(n, vector<double>(n));
    vector<double> x_prev(n), x(n);

    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            fin >> A[i][j];

    for (int i = 0; i < n; i++)
        fin >> x_prev[i];

    double lambda = 0.0, lambda_new = 0.0;
    double eps = 1e-6;
    int maxIter = 1000;

    for (int iter = 0; iter < maxIter; iter++) {

        for (int i = 0; i < n; i++) {
            x[i] = 0.0;
            for (int j = 0; j < n; j++)
                x[i] += A[i][j] * x_prev[j];
        }

        lambda_new = fabs(x[0]);
        for (int i = 1; i < n; i++)
            if (fabs(x[i]) > lambda_new)
                lambda_new = fabs(x[i]);

        if (fabs(lambda_new - lambda) < eps) {
            lambda = lambda_new;
            break;
        }
        lambda = lambda_new;

        for (int i = 0; i < n; i++)
            x_prev[i] = x[i] / lambda;
    }

    fout << "Старшее собственное значение: " << lambda << endl;
    fout << "Собственный вектор:" << endl;
    for (int i = 0; i < n; i++)
        fout << x_prev[i] << " ";
    fout << endl;

    fin.close();
    fout.close();

    return 0;
}